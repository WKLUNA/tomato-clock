/* 页面整体样式 */
page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 容器 */
.container {
  padding: 30rpx;
}

/* 顶部 header */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.header-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-slogan {
  font-size: 32rpx;
  color: #333333;
}

/* 卡片通用样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

/* 卡片标题 */
.card-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

/* 时长选项容器 */
.duration-options {
  display: flex;
  gap: 16rpx;
}

/* 单个时长选项 */
.duration-option {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
  border: 2rpx solid #DDDDDD;
  border-radius: 12rpx;
}

.duration-option text {
  font-size: 28rpx;
  color: #666666;
}

/* 选中状态 */
.duration-option.active {
  background-color: #FF6B6B;
  border: none;
}

.duration-option.active text {
  color: #FFFFFF;
}

/* 清空按钮 */
.clear-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #FFFFFF;
  border: 2rpx solid #FFE0E0;
  border-radius: 12rpx;
}

.clear-btn text {
  font-size: 28rpx;
  color: #FF4444;
}

/* 关于项 */
.about-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.about-item text {
  font-size: 26rpx;
  color: #999999;
}
