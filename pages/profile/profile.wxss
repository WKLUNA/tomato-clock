page {
  background: #F5F5F5;
  min-height: 100vh;
}

.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ===== 顶部用户卡片 ===== */
.user-card {
  background: linear-gradient(135deg, #FF8E8E, #FF6B6B);
  border-radius: 24rpx;
  padding: 50rpx 30rpx 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.25);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
}

.user-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-stat-num {
  font-size: 40rpx;
  font-weight: 700;
}

.user-stat-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

/* ===== 通用卡片容器 ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* ===== 菜单项 ===== */
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  background: #FFF0F0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-item.danger .menu-icon {
  background: #FFE5E5;
}

.menu-text {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.menu-item.danger .menu-title {
  color: #FF4444;
}

.menu-sub {
  font-size: 22rpx;
  color: #999;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 12rpx;
  font-family: monospace;
}

/* ===== 关于卡片 ===== */
.about-card {
  padding: 0 30rpx;
}

.about-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.about-item:last-child {
  border-bottom: none;
}

.about-label {
  font-size: 28rpx;
  color: #666;
}

.about-value {
  font-size: 28rpx;
  color: #999;
}