page {
  background: #F5F5F5;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* ===== 空状态 ===== */
.empty {
  padding-top: 240rpx;
  text-align: center;
}
.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #999;
}

/* ===== 列表与卡片 ===== */
.todo-list {
  padding: 24rpx;
}
.todo-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.todo-info {
  flex: 1;
  min-width: 0;
}
.todo-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.todo-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}
.todo-duration {
  font-size: 24rpx;
  color: #FF6B6B;
  background: #FFE5E5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.todo-count {
  font-size: 24rpx;
  color: #999;
}
.todo-start {
  background: #FF6B6B;
  color: #fff;
  padding: 18rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* ===== 悬浮 + 按钮 ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #FF6B6B;
  color: #fff;
  font-size: 64rpx;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 100;
}

/* ===== 弹窗 ===== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}
.dialog {
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
}
.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}
.dialog-input {
  width: 100%;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
.dialog-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.duration-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.duration-btn {
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid #DDD;
  font-size: 26rpx;
  color: #666;
  background: #fff;
}
.duration-btn.active {
  background: #FF6B6B;
  color: #fff;
  border-color: #FF6B6B;
}
.dialog-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}
.dialog-btn {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
}
.dialog-cancel {
  background: #F5F5F5;
  color: #666;
}
.dialog-confirm {
  background: #FF6B6B;
  color: #fff;
}