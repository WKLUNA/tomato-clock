page {
  background: #F5F5F5;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* ===== 空状态 ===== */
.empty {
  padding-top: 240rpx;
  text-align: center;
}
.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #999;
}

/* ===== 列表与卡片 ===== */
.list {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 已过的：淡化 */
.card.past {
  opacity: 0.55;
}

/* 今天的：渐变高亮卡片 */
.card.today {
  background: linear-gradient(135deg, #FF8E8E, #FF6B6B);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card.today .card-name {
  color: #fff;
}

.card-note {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card.today .card-note {
  color: rgba(255, 255, 255, 0.9);
}

.card-date {
  font-size: 22rpx;
  color: #BBB;
}
.card.today .card-date {
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 右侧天数显示 ===== */
.card-days {
  margin-left: 20rpx;
  text-align: center;
  flex-shrink: 0;
  min-width: 110rpx;
}

.day-label {
  font-size: 22rpx;
  color: #999;
  line-height: 1.2;
}
.card.past .day-label {
  color: #999;
}

.day-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #FF6B6B;
  line-height: 1.1;
}
.card.past .day-num {
  color: #888;
}

.day-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

/* 今天的特殊大字 */
.day-num-big {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

/* ===== FAB 添加按钮 ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #FF6B6B;
  color: #fff;
  font-size: 64rpx;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 100;
}

/* ===== 弹窗 ===== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.dialog {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.dialog-input {
  width: 100%;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.dialog-date {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.dialog-date-label {
  font-size: 28rpx;
  color: #666;
}

.dialog-date-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.dialog-actions {
  display: flex;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.dialog-cancel {
  background: #F5F5F5;
  color: #666;
}

.dialog-confirm {
  background: #FF6B6B;
  color: #fff;
}