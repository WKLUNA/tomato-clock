page {
  background: #F5F5F5;
  min-height: 100vh;
}

.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ===== 日期切换器 ===== */
.date-selector {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-arrow {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #F5F5F5;
  color: #666;
  font-size: 40rpx;
  line-height: 60rpx;
  text-align: center;
  font-family: monospace;
  flex-shrink: 0;
}

.date-arrow.disabled {
  color: #DDD;
  background: #FAFAFA;
}

.date-display {
  text-align: center;
  padding: 0 20rpx;
}

.date-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.date-hint {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 概要卡片 ===== */
.summary-card {
  background: #FFF5F5;
  border-radius: 16rpx;
  padding: 22rpx 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.summary-text {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
}

/* ===== 记录列表 ===== */
.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.record-emoji {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #FFF0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.record-time {
  font-size: 24rpx;
  color: #666;
}

.record-duration {
  font-size: 22rpx;
  color: #FF6B6B;
  background: #FFE5E5;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.record-delete {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FAFAFA;
  color: #CCC;
  font-size: 32rpx;
  line-height: 50rpx;
  text-align: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 空状态 ===== */
.empty {
  padding-top: 200rpx;
  text-align: center;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.empty-action {
  display: inline-block;
  background: #FF6B6B;
  color: #fff;
  padding: 16rpx 50rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
}