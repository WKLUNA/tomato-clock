page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部待办名 */
.header {
  margin-bottom: 80rpx;
  text-align: center;
}
.todo-name {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
}

/* 按钮容器 */
.btn-container {
  display: flex;
  gap: 40rpx;
  margin-top: 80rpx;
}

/* 按钮基础样式 */
.btn {
  width: 200rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  padding: 0;
  margin: 0;
  background: none;
}
.btn::after {
  border: none;
}

/* 主按钮（开始/暂停）：番茄红 */
.btn-primary {
  background-color: #FF6B6B;
}
.btn-primary text {
  color: #FFFFFF;
  font-size: 32rpx;
}

/* 危险按钮（结束）：白底红字 */
.btn-danger {
  background-color: #fff;
  border: 2rpx solid #FFCCCC;
}
.btn-danger text {
  color: #FF4444;
  font-size: 32rpx;
}