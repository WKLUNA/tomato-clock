<view class="container">
  <!-- 顶部待办名 -->
  <view class="header">
    <view class="todo-name">{{todoName}}</view>
  </view>

  <!-- 进度环组件（接口不变） -->
  <progress-ring
    total="{{currentDuration * 60}}"
    remaining="{{minutes * 60 + seconds}}"
    running="{{isRunning}}"
  />

  <!-- 按钮区域 -->
  <view class="btn-container">
    <!-- 开始/暂停 -->
    <view class="btn btn-primary" bindtap="onToggleTimer">
      <text wx:if="{{!isRunning}}">开始</text>
      <text wx:else>暂停</text>
    </view>

    <!-- 结束 -->
    <view class="btn btn-danger" bindtap="onEnd">
      <text>结束</text>
    </view>
  </view>
</view>