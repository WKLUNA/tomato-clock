/* 组件容器 */
.ring-container {
  position: relative;
  width: 500rpx;
  height: 500rpx;
  margin: 0 auto;
}

/* canvas 画布，铺满容器 */
.ring-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 中间文字区域，绝对定位居中 */
.ring-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

/* 时间文字 */
.time-text {
  display: block;
  font-size: 88rpx;
  font-weight: 600;
  color: #333333;
  font-variant-numeric: tabular-nums;
}

/* 状态文字 */
.status-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-top: 8rpx;
}
